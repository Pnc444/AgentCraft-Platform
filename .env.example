# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DJANGO_SETTINGS_MODULE=config.settings.development
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentcraft
REDIS_URL=redis://redis:6379/0
POSTGRES_PORT=5433
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Anthropic (AI tutor — not wired up yet)
ANTHROPIC_API_KEY=

# Frontend
INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=/api/v1

# NOTE: DATABASE_URL above uses the Docker service name "db", so it only
# resolves inside docker-compose. Running the backend locally with a venv?
# Either point it at the compose Postgres:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agentcraft
# or comment DATABASE_URL out entirely to fall back to SQLite.
