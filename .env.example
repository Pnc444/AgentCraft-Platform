# ---- Django ----
SECRET_KEY=change-me-to-any-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Local dev without Docker: leave DATABASE_URL unset to fall back to SQLite,
# or point it at the compose Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agentcraft
# REDIS_URL=redis://localhost:6379/0

# ---- Frontend ----
# Browser API calls are proxied through Next (see next.config.mjs), so this
# usually stays unset. Override only if the API is hosted elsewhere.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# INTERNAL_API_URL=http://backend:8000

# ---- Ports (docker-compose) ----
# POSTGRES_PORT=5433
# REDIS_PORT=6379
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
