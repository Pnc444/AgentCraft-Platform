# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DJANGO_SETTINGS_MODULE=config.settings.development
# Omit DATABASE_URL for local dev → SQLite at backend/db.sqlite3 (see config/settings/base.py).
# Docker Compose sets postgres DATABASE_URL on the backend service.
REDIS_URL=
POSTGRES_PORT=5434
REDIS_PORT=6380
BACKEND_PORT=8001
FRONTEND_PORT=3001

# Anthropic (AI tutor — not wired up yet)
ANTHROPIC_API_KEY=

# Frontend (local dev — call the API directly; ports 8000/3000 are often taken by other stacks)
INTERNAL_API_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1

# Docker Compose: copy to .env, then `docker compose up --build` and
# `docker compose exec backend python manage.py seed_demo`
#
# Local dev (no Docker): `./scripts/dev-local.sh`
# Login after seed: demo_student / demo1234
