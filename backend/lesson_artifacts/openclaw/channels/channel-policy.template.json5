// Door policy: every door starts locked, and this file keeps it that way.
{
  session: {
    // Each person gets a private conversation notebook. Threads never blur.
    dmScope: "per-channel-peer",
  },
  channels: {
    slack: {
      // Doorbell with a code: strangers get a pairing code and silence
      // until you approve them with `openclaw pairing approve slack <code>`.
      dmPolicy: "pairing",
    },
    discord: {
      dmPolicy: "pairing",
    },
    whatsapp: {
      dmPolicy: "pairing",
      groups: {
        // In shared rooms, the assistant is a polite guest:
        // it only answers when called by name.
        "*": { requireMention: true },
      },
    },
  },
}
